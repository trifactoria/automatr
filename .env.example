# ---------- Host API ----------
AUTOMATR_HOST=127.0.0.1
AUTOMATR_PORT=8766

# Root data directory (host filesystem)
AUTOMATR_DATA_DIR=/home/andy/projects/automatr/data

# SQLite DB path (host filesystem)
AUTOMATR_DB_PATH=/home/andy/projects/automatr/data/automatr.db

# ---------- Docker ----------
# Which docker binary to call
AUTOMATR_DOCKER_BIN=docker

# Base image name (later)
AUTOMATR_BASE_IMAGE=automatr-base:dev

# noVNC base (later, host API can generate urls)
AUTOMATR_NOVNC_BASE=http://127.0.0.1

# ---------- UI ----------
# Next.js reads this (set in src/.env.local)
# NEXT_PUBLIC_AUTOMATR_API=http://127.0.0.1:8766


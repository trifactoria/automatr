# ---------- Host API ----------
AUTOMATR_HOST=127.0.0.1
AUTOMATR_PORT=8766

# ---------- Host Filesystem Storage ----------
# Root data directory (host filesystem, use relative path for portability)
AUTOMATR_DATA_DIR=./data

# Where container-specific folders live on the host:
# Structure: ${AUTOMATR_DATA_DIR}/containers/<container_name>
AUTOMATR_CONTAINERS_DIR=${AUTOMATR_DATA_DIR}/containers

# SQLite database path
AUTOMATR_DB_PATH=${AUTOMATR_DATA_DIR}/automatr.db

# ---------- Docker Runtime ----------
# Which docker binary to call
AUTOMATR_DOCKER_BIN=docker

# Docker image tag for runtime containers
AUTOMATR_RUNTIME_IMAGE=automatr-runtime:dev

# Docker network (optional, empty means use default bridge)
AUTOMATR_DOCKER_NETWORK=

# ---------- Headless Desktop Settings ----------
# Desired headless desktop geometry for automation containers
AUTOMATR_SCREEN_W=1366
AUTOMATR_SCREEN_H=768
AUTOMATR_SCREEN_D=24

# ---------- noVNC Configuration ----------
# Port allocation strategy
# If set, API allocates noVNC ports starting at this base (e.g., 6100, 6101...)
AUTOMATR_NOVNC_PORT_BASE=6100

# noVNC path to iframe (depends on image setup)
AUTOMATR_NOVNC_PATH=/vnc.html?autoconnect=1&resize=remote

# ---------- Container Internal Paths ----------
# These paths are used inside the runtime containers
# Runner queue folder inside container (mounted from host)
AUTOMATR_CONTAINER_ROOT=/automatr
AUTOMATR_QUEUE_DIR=/automatr/queue

# ---------- UI ----------
# Next.js reads this (set in src/.env.local)
# NEXT_PUBLIC_AUTOMATR_API=http://127.0.0.1:8766

# ---------- CORS Origins ----------
# Optional, defaults to localhost:3000
# AUTOMATR_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

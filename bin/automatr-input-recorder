#!/usr/bin/env python3
"""
Automatr Input Recorder (xinput-based)

Records mouse button press/release events with screen coordinates.
Output: JSONL lines to /automatr/logs/input_events.jsonl
"""

from __future__ import annotations

import json
import os
import re
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

DISPLAY = os.getenv("DISPLAY", ":99")
ROOT = Path(os.getenv("AUTOMATR_CONTAINER_ROOT", "/automatr"))
OUT = ROOT / "logs" / "input_events.jsonl"
OUT.parent.mkdir(parents=True, exist_ok=True)
OUT.touch(exist_ok=True)

DETAIL_RE = re.compile(r"detail:\s*(\d+)")
EVENT_PRESS_RE = re.compile(r"\bRawButtonPress\b")
EVENT_RELEASE_RE = re.compile(r"\bRawButtonRelease\b")


def get_mouse_xy() -> tuple[int, int]:
    try:
        r = subprocess.run(
            ["xdotool", "getmouselocation", "--shell"],
            capture_output=True,
            text=True,
            env={"DISPLAY": DISPLAY, **os.environ},
            timeout=1,
        )
        x = y = 0
        for line in r.stdout.splitlines():
            if line.startswith("X="):
                x = int(line.split("=", 1)[1])
            elif line.startswith("Y="):
                y = int(line.split("=", 1)[1])
        return x, y
    except Exception:
        return 0, 0


def write_event(button: int, action: str) -> None:
    x, y = get_mouse_xy()
    evt = {
        "timestamp": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
        "type": "mouse",
        "data": {"button": button, "action": action, "x": x, "y": y},
    }
    with OUT.open("a", encoding="utf-8") as f:
        f.write(json.dumps(evt) + "\n")
        f.flush()


def find_pointer_device_id() -> str | None:
    """
    Pick a pointer device id suitable for xinput test-xi2.
    In Xvfb you'll often only have "Virtual core pointer" and/or "XTEST pointer".
    Prefer Virtual core pointer; fall back to first pointer; avoid XTEST if possible.
    """
    r = subprocess.run(
        ["xinput", "list"],
        capture_output=True,
        text=True,
        env={"DISPLAY": DISPLAY, **os.environ},
    )
    lines = r.stdout.splitlines()

    candidates: list[tuple[str, str]] = []  # (name, id)

    for line in lines:
        low = line.lower()
        if "pointer" not in low:
            continue
        if "id=" not in line:
            continue

        # name is everything before "id="
        name = line.split("id=", 1)[0].strip(" \t⎜↳")
        dev_id = line.split("id=", 1)[1].split()[0].strip()
        candidates.append((name, dev_id))

    if not candidates:
        return None

    # Prefer Virtual core pointer
    for name, dev_id in candidates:
        if "virtual core pointer" in name.lower():
            return dev_id

    # Otherwise prefer a non-XTEST pointer
    for name, dev_id in candidates:
        if "xtest" not in name.lower():
            return dev_id

    # Worst case: return first
    return candidates[0][1]


def main() -> int:
    dev_id = find_pointer_device_id()
    if not dev_id:
        print("No pointer device found via xinput list", file=sys.stderr, flush=True)
        return 2

    # Start xinput event stream
    proc = subprocess.Popen(
        ["xinput", "test-xi2", "--root", dev_id],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
        env={"DISPLAY": DISPLAY, **os.environ},
        bufsize=1,
    )

    pending_action: str | None = None

    # Parse multi-line events:
    # EVENT type ... RawButtonPress  -> pending_action="press"
    # next lines include "detail: N" -> emit event and clear pending_action
    assert proc.stdout is not None
    for raw in proc.stdout:
        line = raw.strip()

        if EVENT_PRESS_RE.search(line):
            pending_action = "press"
            continue

        if EVENT_RELEASE_RE.search(line):
            pending_action = "release"
            continue

        if pending_action:
            m = DETAIL_RE.search(line)
            if m:
                button = int(m.group(1))
                write_event(button, pending_action)
                pending_action = None

    return 0


if __name__ == "__main__":
    raise SystemExit(main())

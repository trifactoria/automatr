#!/usr/bin/env bash
set -euo pipefail

NAME="automatr-prosody"
IMAGE="prosody/prosody:latest"
DOMAIN="${AUTOMATR_XMPP_DOMAIN:-automatr-xmpp.local}"
CFG="$(pwd)/config/prosody/prosody.cfg.lua"
VOL="automatr-prosody-data"

# Network to use (default: automatr-net)
NET="${DOCKER_NETWORK:-automatr-net}"
ALIAS="${DOMAIN}"

if [[ ! -f "$CFG" ]]; then
  echo "Missing prosody config: $CFG" >&2
  exit 1
fi

# If it's already running, do nothing
if docker ps --format '{{.Names}}' | grep -qx "$NAME"; then
  echo "$NAME already running"
  exit 0
fi

# If container exists but is stopped, start it
if docker ps -a --format '{{.Names}}' | grep -qx "$NAME"; then
  docker start "$NAME" >/dev/null
  echo "Started existing $NAME"
  exit 0
fi

docker run -d \
  --name "$NAME" \
  --network "$NET" \
  --network-alias "$ALIAS" \
  -p 5222:5222 \
  -p 5280:5280 \
  -v "$CFG:/etc/prosody/prosody.cfg.lua:ro" \
  -v "$VOL:/var/lib/prosody" \
  "$IMAGE"

echo "Prosody is up: $NAME (domain: $DOMAIN, net: $NET, alias: $ALIAS)"

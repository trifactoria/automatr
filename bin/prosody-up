#!/usr/bin/env bash
set -euo pipefail

NAME="${AUTOMATR_PROSODY_NAME:-automatr-prosody}"
IMAGE="${AUTOMATR_PROSODY_IMAGE:-prosody/prosody:latest}"

# IMPORTANT: domain is the XMPP VirtualHost (JIDs use this), NOT your machine hostname.
DOMAIN="${AUTOMATR_XMPP_DOMAIN:-xps.local}"

# docker network (match app.py)
NET="${AUTOMATR_DOCKER_NETWORK:-automatr-net}"

# ports
C2S_PORT="${AUTOMATR_PROSODY_PORT:-5222}"
HTTP_PORT="${AUTOMATR_PROSODY_HTTP_PORT:-5280}"
HTTPS_PORT="${AUTOMATR_PROSODY_HTTPS_PORT:-5281}"


ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CFG_DIR="$ROOT/config/prosody"
DATA_DIR="${AUTOMATR_PROSODY_DATA_DIR:-$ROOT/data/prosody}"
CERT_DIR="$DATA_DIR/certs"

mkdir -p "$DATA_DIR" "$CERT_DIR"

if docker ps --format '{{.Names}}' | grep -qx "$NAME"; then
  echo "Prosody already running: $NAME"
  exit 0
fi

# If container exists but stopped, remove it so config/env changes apply cleanly
if docker ps -a --format '{{.Names}}' | grep -qx "$NAME"; then
  docker rm -f "$NAME" >/dev/null 2>&1 || true
fi

echo "Starting Prosody:"
echo "  name=$NAME"
echo "  domain=$DOMAIN"
echo "  net=$NET"
echo "  c2s_port=$C2S_PORT http_port=$HTTP_PORT"

docker run -d \
  --name "$NAME" \
  --network "$NET" \
  -p "${C2S_PORT}:5222" \
  -p "${HTTP_PORT}:5280" \
  -p "${HTTPS_PORT}:5281" \
  -e "AUTOMATR_XMPP_DOMAIN=$DOMAIN" \
  -v "$CFG_DIR/prosody.cfg.lua:/etc/prosody/prosody.cfg.lua:ro" \
  -v "$DATA_DIR:/var/lib/prosody:rw" \
  -v "$CERT_DIR:/etc/prosody/certs:rw" \
  "$IMAGE" >/dev/null

# Give it a moment to come up
sleep 0.8

# Generate a self-signed cert w/ SANs (fixes "legacy CN" errors)
docker exec -u 0 "$NAME" sh -lc "
set -e
DOMAIN='${DOMAIN}'
CRT=\"/etc/prosody/certs/\$DOMAIN.crt\"
KEY=\"/etc/prosody/certs/\$DOMAIN.key\"

if [ ! -s \"\$CRT\" ] || [ ! -s \"\$KEY\" ]; then
  echo \"[prosody-up] generating cert for \$DOMAIN (with SANs)\"
  if command -v openssl >/dev/null 2>&1; then
    openssl req -x509 -newkey rsa:2048 -nodes -days 3650 \
      -keyout \"\$KEY\" \
      -out \"\$CRT\" \
      -subj \"/CN=\$DOMAIN\" \
      -addext \"subjectAltName=DNS:\$DOMAIN,DNS:conference.\$DOMAIN\"
    chmod 600 \"\$KEY\" || true
  else
    echo \"[prosody-up] WARNING: openssl not present in image; TLS cert not generated\"
  fi
fi
"

docker exec -u 0 automatr-prosody sh -lc '
set -eux
DOMAIN="${AUTOMATR_XMPP_DOMAIN:-xps.local}"
for d in "$DOMAIN" "conference.$DOMAIN"; do
  crt="/etc/prosody/certs/$d.crt"
  key="/etc/prosody/certs/$d.key"
  if [ -f "$crt" ] && [ -f "$key" ]; then
    chown prosody:prosody "$crt" "$key" || true
    chmod 644 "$crt" || true
    chmod 640 "$key" || true
  fi
done
'

echo "Prosody started: $NAME"

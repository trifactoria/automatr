#!/usr/bin/env bash
docker rm -f automatr-caddy >/dev/null 2>&1 || true
docker run -d --name automatr-caddy --restart unless-stopped \
  --network host \
  -v "$PWD/Caddyfile:/etc/caddy/Caddyfile:ro" \
  -v "$PWD/certs:/certs:ro" \
  -v "$PWD/caddy-data:/data" \
  -v "$PWD/caddy-config:/config" \
  caddy:2

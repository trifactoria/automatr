#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."
export $(grep -v '^#' .env.example | xargs) >/dev/null 2>&1 || true

# prefer real .env if you create it
if [[ -f .env ]]; then
  set -a
  source .env
  set +a
fi

exec python3 -m uvicorn app:app --host "${AUTOMATR_HOST:-127.0.0.1}" --port "${AUTOMATR_PORT:-8766}" --reload

